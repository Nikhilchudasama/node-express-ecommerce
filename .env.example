# =============================================================================
# Environment variables for all stages (development, test, production)
# Copy this file to .env and fill in the actual values before running.
# =============================================================================

# --- Database ---
# PostgreSQL connection string (format: postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public)
# For Docker: postgresql://postgres:postgres@db:5432/node-ecom?schema=public
# For local:  postgresql://postgres:@localhost:5432/node-ecom?schema=public
DATABASE_URL=postgresql://postgres:@localhost:5432/node-ecom?schema=public

# --- Auth ---
# JWT secret for signing access tokens (REQUIRED - change in production)
JWT_SECRET=dev-local-secret-change-me

# Optional refresh token secret. Falls back to JWT_SECRET if omitted.
JWT_REFRESH_SECRET=

# --- Server ---
PORT=3000

# --- Runtime ---
NODE_ENV=development
CORS_ORIGIN=*
LOG_LEVEL=info
