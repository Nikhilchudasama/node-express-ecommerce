        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json?.data?.tokens?.accessToken) pm.environment.set('accessToken', json.data.tokens.accessToken);",
                  "if (json?.data?.tokens?.refreshToken) pm.environment.set('refreshToken', json.data.tokens.refreshToken);",
                  "if (json?.data?.user?.id) pm.environment.set('userId', json.data.user.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
