{
  "name": "node-express-ecommerce",
  "version": "1.0.0",
  "private": true,
  "description": "Production-ready Node.js REST API for an eCommerce system — with auth, products, categories, cart, orders, reviews, coupons, and product images",
  "main": "dist/index.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Nikhilchudasama/node-express-ecommerce.git"
  },
  "bugs": {
    "url": "https://github.com/Nikhilchudasama/node-express-ecommerce/issues"
  },
  "homepage": "https://github.com/Nikhilchudasama/node-express-ecommerce#readme",
  "scripts": {
    "dev": "ts-node-dev --respawn src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest --detectOpenHandles --forceExit",
    "lint": "eslint . --ext .ts",
    "prisma:generate": "npx prisma generate",
    "prisma:migrate": "npx prisma migrate dev",
    "prisma:push": "npx prisma db push",
    "prisma:studio": "npx prisma studio",
    "prisma:seed": "node prisma/seed.js"
  },
  "keywords": [
    "ecommerce",
    "api",
    "node",
    "express",
    "typescript",
    "prisma",
    "postgresql",
    "jwt",
    "zod"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@types/pg": "^8.20.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.21.0",
    "winston": "^3.19.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.9.1",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "jest": "^30.4.2",
    "prettier": "^3.8.3",
    "prisma": "^7.8.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.3"
  }
}
